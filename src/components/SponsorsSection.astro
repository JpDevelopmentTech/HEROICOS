---
import SectionLabel from './ui/SectionLabel.astro';

const sponsors = [
  { name: 'NIKE', fontSize: '28px', letterSpacing: '6px' },
  { name: 'GATORADE', fontSize: '22px', letterSpacing: '4px' },
  { name: 'GARMIN', fontSize: '26px', letterSpacing: '5px' },
  { name: 'FISIO+', fontSize: '26px', letterSpacing: '5px' },
];
---

<section id="beneficios" class="flex flex-col items-center gap-12 bg-dark-950 px-[120px] py-20">
  <SectionLabel text="PARTNERS" />

  <h2 class="max-w-[700px] text-center font-heading text-4xl font-extrabold italic leading-[1.1] tracking-[-1px] text-white">
    BENEFICIOS EXCLUSIVOS<br />CON NUESTROS ALIADOS.
  </h2>

  <p class="text-center font-body text-base text-gray-400">
    Descuentos y acceso preferencial por ser parte del club.
  </p>

  <div class="flex w-full justify-center gap-8">
    {
      sponsors.map((sponsor) => (
        <div class="flex h-[120px] w-[260px] items-center justify-center rounded-xl border border-dark-700 bg-dark-800">
          <span
            class="font-heading font-extrabold text-white/25"
            style={`font-size: ${sponsor.fontSize}; letter-spacing: ${sponsor.letterSpacing}`}
          >
            {sponsor.name}
          </span>
        </div>
      ))
    }
  </div>
</section>
