---
---

<div id="login-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-dark-950/80" role="dialog" aria-modal="true" aria-labelledby="login-title">
  <div class="relative w-[480px] overflow-hidden rounded-2xl border border-dark-700 bg-dark-900 shadow-2xl">
    <!-- Accent Line -->
    <div class="h-[3px] w-full rounded-t-2xl bg-accent"></div>

    <div class="flex flex-col gap-7 px-12 py-10">
      <!-- Header Row -->
      <div class="flex items-center justify-between">
        <div class="flex flex-col gap-2">
          <h2 id="login-title" class="font-heading text-[26px] font-extrabold italic leading-tight tracking-[-1px] text-white">BIENVENIDO DE VUELTA</h2>
          <p class="font-body text-sm text-gray-400">Inicia sesión para acceder a tu cuenta.</p>
        </div>
        <button type="button" data-close-modal="login-modal" class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-dark-700 bg-dark-800 text-gray-400 transition-colors hover:border-gray-600 hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>

      <!-- Form Fields -->
      <form class="flex flex-col gap-5" id="login-form">
        <!-- Email -->
        <div class="flex flex-col gap-1.5">
          <label for="login-email" class="font-body text-[13px] font-medium text-gray-200">Correo electrónico</label>
          <div class="flex h-12 items-center gap-2.5 rounded-lg border border-dark-700 bg-dark-800 px-4 focus-within:border-accent">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-gray-600"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <input
              type="email"
              id="login-email"
              name="email"
              placeholder="correo@ejemplo.com"
              required
              class="w-full bg-transparent font-body text-sm text-white placeholder-gray-600 outline-none"
            />
          </div>
        </div>

        <!-- Password -->
        <div class="flex flex-col gap-1.5">
          <div class="flex items-center justify-between">
            <label for="login-password" class="font-body text-[13px] font-medium text-gray-200">Contraseña</label>
            <button type="button" class="font-body text-xs font-medium text-accent transition-opacity hover:opacity-80">¿Olvidaste tu contraseña?</button>
          </div>
          <div class="flex h-12 items-center justify-between rounded-lg border border-dark-700 bg-dark-800 px-4 focus-within:border-accent">
            <div class="flex items-center gap-2.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-gray-600"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <input
                type="password"
                id="login-password"
                name="password"
                placeholder="••••••••"
                required
                class="w-full bg-transparent font-body text-sm text-white placeholder-gray-600 outline-none"
              />
            </div>
            <button type="button" class="toggle-password shrink-0 text-gray-600 transition-colors hover:text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-off"><path d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49"/><path d="M14.084 14.158a3 3 0 0 1-4.242-4.242"/><path d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143"/><path d="m2 2 20 20"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye hidden"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <!-- Remember me -->
        <label class="flex cursor-pointer items-center gap-2.5">
          <input type="checkbox" name="remember" class="peer hidden" />
          <span class="flex h-[18px] w-[18px] shrink-0 items-center justify-center rounded border border-dark-700 bg-dark-800 transition-colors peer-checked:border-accent peer-checked:bg-accent/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-accent opacity-0"><path d="M20 6 9 17l-5-5"/></svg>
          </span>
          <span class="font-body text-[13px] text-gray-400">Recordar mi sesión</span>
        </label>

        <!-- Submit Button -->
        <button
          type="submit"
          class="flex h-12 w-full items-center justify-center gap-2.5 rounded-lg bg-accent font-heading text-sm font-bold tracking-[1px] text-dark-950 transition-opacity hover:opacity-90"
        >
          INICIAR SESIÓN
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </form>

      <!-- Register link -->
      <p class="flex items-center justify-center gap-1.5 font-body text-[13px]">
        <span class="text-gray-500">¿No tienes cuenta?</span>
        <button type="button" data-switch-to="register-modal" class="font-semibold text-accent transition-opacity hover:opacity-80">Regístrate</button>
      </p>
    </div>
  </div>
</div>

<style>
  #login-modal.active {
    display: flex;
  }

  label:has(input[type="checkbox"]:checked) span:first-of-type svg {
    opacity: 1;
  }

  label:has(input[type="checkbox"]:checked) span:first-of-type {
    border-color: var(--color-accent);
    background-color: rgb(0 240 255 / 0.1);
  }
</style>

<script>
  import { signIn } from '../lib/auth';

  function setupLoginForm() {
    const form = document.getElementById('login-form') as HTMLFormElement | null;
    if (!form) return;

    // Remove previous listener by cloning
    const newForm = form.cloneNode(true) as HTMLFormElement;
    form.parentNode?.replaceChild(newForm, form);

    newForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(newForm);
      const email = formData.get('email') as string;
      const password = formData.get('password') as string;

      const submitBtn = newForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.innerHTML;

      // Remove previous error
      newForm.querySelector('.auth-error')?.remove();

      try {
        submitBtn.disabled = true;
        submitBtn.innerHTML = `
          <svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
          INGRESANDO...
        `;

        await signIn(email, password);

        // Close modal on success
        document.getElementById('login-modal')?.classList.remove('active');
        document.body.style.overflow = '';
        newForm.reset();
      } catch (err: any) {
        const errorMsg = document.createElement('div');
        errorMsg.className = 'auth-error flex items-center gap-2 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 font-body text-sm text-red-400';
        errorMsg.textContent = getErrorMessage(err.message);
        newForm.querySelector('button[type="submit"]')?.insertAdjacentElement('beforebegin', errorMsg);
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
      }
    });
  }

  function getErrorMessage(message: string): string {
    if (message.includes('Invalid login credentials')) return 'Correo o contraseña incorrectos.';
    if (message.includes('Email not confirmed')) return 'Confirma tu correo electrónico primero.';
    if (message.includes('Too many requests')) return 'Demasiados intentos. Espera un momento.';
    return 'Error al iniciar sesión. Intenta de nuevo.';
  }

  setupLoginForm();
  document.addEventListener('astro:after-swap', setupLoginForm);
</script>
