    </div>
  </div>

  <hr class="border-dark-800" />

  <!-- Bottom -->
  <div class="flex flex-col items-center gap-4 md:flex-row md:justify-between">
    <!-- Brand -->
    <div class="flex items-center gap-2.5">
      <img src="/images/logo.png" alt="HEROICOS" class="h-8 w-auto" />
      <span class="font-heading text-sm font-extrabold tracking-[3px] text-white">
        HEROICOS RUN CLUB
      </span>
