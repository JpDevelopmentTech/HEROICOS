<footer class="flex flex-col gap-8 bg-dark-950 px-5 pb-8 pt-10 md:gap-10 md:px-[120px] md:pb-10 md:pt-[60px]">
  <!-- WhatsApp Community CTA -->
  <div class="relative overflow-hidden rounded-2xl border border-accent/20 bg-gradient-to-r from-accent/10 via-accent/5 to-transparent p-6 md:p-10">
    <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-accent/5 blur-3xl"></div>
    <div class="absolute -bottom-10 -left-10 h-32 w-32 rounded-full bg-accent/5 blur-3xl"></div>
    <div class="relative flex flex-col items-center gap-5 text-center md:flex-row md:text-left">
      <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-[#25D366]/15 md:h-20 md:w-20">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="#25D366" class="md:h-11 md:w-11">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </div>
      <div class="flex flex-1 flex-col gap-2">
        <span class="font-heading text-xl font-extrabold tracking-[-0.5px] text-white md:text-2xl">
          Se parte de nuestra comunidad
        </span>
        <p class="font-body text-sm leading-relaxed text-gray-400">
          Unete al grupo de WhatsApp donde compartimos rutas, eventos y motivacion entre corredores.
        </p>
      </div>
      <a
        href="https://chat.whatsapp.com/HEROICOS"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-2.5 rounded-xl bg-[#25D366] px-8 py-4 font-heading text-sm font-extrabold tracking-[1px] text-white shadow-lg shadow-[#25D366]/20 transition-all hover:scale-[1.02] hover:shadow-xl hover:shadow-[#25D366]/30"
      >
        UNIRME AL GRUPO
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
