    <!-- Instagram -->
    <a href="https://instagram.com/heroicosrunclub" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-gray-500 transition-colors hover:text-accent">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
      </svg>
      <span class="font-body text-sm font-medium">@heroicosrunclub</span>
    </a>

    <!-- Copyright -->
    <div class="flex flex-col items-center gap-1 md:items-end">
      <span class="font-body text-xs text-gray-600">
        &copy; 2026 Desarrollado por JP Development
      </span>
      <span class="font-heading text-[11px] italic font-semibold text-accent/25">
        "La linea de meta es solo el comienzo."
      </span>
    </div>
  </div>
</footer>
